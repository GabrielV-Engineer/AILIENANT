{
  "name": "ailienant-extension",
  "displayName": "ailienant-extension",
  "description": "AI-assisted engineering platform",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.115.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ailienant-sidebar",
          "title": "AILIENANT",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "ailienant-sidebar": [
        {
          "type": "webview",
          "id": "ailienant.sessionBrowser",
          "name": "AILIENANT Sessions",
          "icon": "media/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "ailienant.openWorkspace",
        "title": "Open Workspace",
        "category": "AILIENANT"
      },
      {
        "command": "ailienant.newSession",
        "title": "New Session",
        "category": "AILIENANT"
      },
      {
        "command": "ailienant.showMctsDiff",
        "title": "Show MCTS Dream Diff",
        "category": "AILIENANT"
      },
      {
        "command": "ailienant.applyMerge",
        "title": "Apply MCTS Merge",
        "category": "AILIENANT"
      }
    ],
    "keybindings": [
      {
        "command": "ailienant.openWorkspace",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/vscode": "^1.115.0",
    "@types/ws": "^8.18.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "lucide-react": "^1.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactflow": "^11.11.4",
    "ws": "^8.20.0"
  }
}
