{
  "name": "ailienant-extension",
  "displayName": "ailienant-extension",
  "description": "AI-assisted engineering platform",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.115.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ailienant-sidebar",
          "title": "AILIENANT",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "ailienant-sidebar": [
        {
          "type": "webview",
          "id": "ailienant.sessionBrowser",
          "name": "AILIENANT Sessions",
          "icon": "media/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "ailienant.openWorkspace",
        "title": "Open AILIENANT Workspace",
        "category": "AILIENANT",
        "icon": "media/icon.svg"
      },
      {
        "command": "ailienant.scaffoldDevcontainer",
        "title": "Scaffold devcontainer.json",
        "category": "AILIENANT"
      },
      {
        "command": "ailienant.newSession",
        "title": "New AILIENANT Session",
        "category": "AILIENANT",
        "icon": "media/icon-color.svg"
      },
      {
        "command": "ailienant.showMctsDiff",
        "title": "Show MCTS Dream Diff",
        "category": "AILIENANT"
      },
      {
        "command": "ailienant.applyMerge",
        "title": "Apply MCTS Merge",
        "category": "AILIENANT"
      },
      {
        "command": "ailienant.inlineEdit",
        "title": "Edit with AILIENANT (Cmd+K)",
        "category": "AILIENANT"
      },
      {
        "command": "ailienant.acceptInlineEdit",
        "title": "Accept Inline Edit",
        "category": "AILIENANT"
      },
      {
        "command": "ailienant.rejectInlineEdit",
        "title": "Reject Inline Edit",
        "category": "AILIENANT"
      },
      {
        "command": "ailienant.toggleIncognito",
        "title": "Toggle Incognito Mode",
        "category": "AILIENANT"
      },
      {
        "command": "ailienant.triggerDreamingRun",
        "title": "Trigger Dreaming / Consolidate Memory",
        "category": "AILIENANT"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "ailienant.newSession",
          "group": "navigation",
          "when": "true"
        }
      ]
    },
    "keybindings": [
      {
        "command": "ailienant.openWorkspace",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a"
      },
      {
        "command": "ailienant.inlineEdit",
        "key": "ctrl+k",
        "mac": "cmd+k",
        "when": "editorTextFocus && editorHasSelection"
      },
      {
        "command": "ailienant.acceptInlineEdit",
        "key": "tab",
        "when": "editorTextFocus && ailienant.inlineEditActive"
      },
      {
        "command": "ailienant.rejectInlineEdit",
        "key": "escape",
        "when": "editorTextFocus && ailienant.inlineEditActive"
      }
    ],
    "configuration": {
      "title": "AILIENANT",
      "properties": {
        "ailienant.coreStartCommand": {
          "type": "string",
          "default": "",
          "description": "Shell command to start the AILIENANT core backend. Example: 'cd ailienant-core && .venv/Scripts/python -m uvicorn main:app --reload'. Leave empty to disable the Start Core button."
        },
        "ailienant.autoStartCore": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the AILIENANT Core backend when a session opens if it is not already reachable. The manual 'Start Core' button still works when this is disabled."
        },
        "ailienant.docsUrl": {
          "type": "string",
          "default": "",
          "description": "URL opened by the command menu's Support → Help documents action. Leave empty to be prompted to configure it."
        },
        "ailienant.notifications.hitlNativeMode": {
          "type": "string",
          "enum": [
            "auto",
            "always",
            "never"
          ],
          "enumDescriptions": [
            "Show the OS toast only when the chat panel is hidden (recommended).",
            "Always show the OS toast, even when the chat panel is visible.",
            "Never show OS toasts; HITL approvals are only surfaced inside the chat panel."
          ],
          "default": "auto",
          "description": "How AILIENANT surfaces Human-In-The-Loop approval requests via native VS Code notifications (Phase 7.11.7)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@devcontainers/cli": "0.87.0",
    "@types/diff": "^7.0.2",
    "@types/dompurify": "^3.0.5",
    "@types/jsdom": "^28.0.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/vscode": "^1.115.0",
    "@types/ws": "^8.18.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "jsdom": "^29.1.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "diff": "^7.0.0",
    "dompurify": "^3.4.6",
    "lucide-react": "^1.16.0",
    "react": "^18.3.1",
    "react-diff-viewer-continued": "^4.2.2",
    "react-dom": "^18.3.1",
    "reactflow": "^11.11.4",
    "regl-scatterplot": "^1.16.0",
    "shiki": "^4.2.0",
    "ws": "^8.20.0",
    "zustand": "^4.5.7"
  }
}
